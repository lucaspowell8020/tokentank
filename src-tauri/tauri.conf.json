{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "TokenTank",
  "version": "0.3.0",
  "identifier": "com.agentshortlist.tokentank",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "TokenTank",
        "width": 380,
        "height": 660,
        "minWidth": 340,
        "minHeight": 560,
        "resizable": true,
        "visible": true,
        "center": true,
        "alwaysOnTop": true,
        "skipTaskbar": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "icon": ["icons/32x32.png", "icons/128x128.png", "icons/icon.ico"]
  }
}
